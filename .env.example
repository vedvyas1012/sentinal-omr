PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/neet_omr
JWT_SECRET=your-secret-here
NODE_ENV=development

# Shared secret the hub scan agent uses to submit sheets (POST /api/hub/verify-image)
HUB_API_KEY=change-this-machine-key

# Ed25519 signing keys (PEM). If unset, a dev keypair is generated and persisted
# to server/crypto/keys/ on first run. In production inject both and keep the
# private key in an HSM.
# SIGNING_PRIVATE_KEY=
# SIGNING_PUBLIC_KEY=
